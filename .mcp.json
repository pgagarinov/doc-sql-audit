{
  "mcpServers": {
    "doc-sql-audit": {
      "command": "toolbox",
      "args": ["--prebuilt", "postgres", "--stdio"],
      "env": {
        "POSTGRES_HOST": "127.0.0.1",
        "POSTGRES_PORT": "5432",
        "POSTGRES_USER": "postgres",
        "POSTGRES_PASSWORD": "postgres",
        "POSTGRES_DATABASE": "doc_sql_audit"
      }
    }
  }
}
